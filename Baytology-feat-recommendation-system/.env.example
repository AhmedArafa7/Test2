WORKER_ENABLED=true
RABBITMQ_ENABLED=true
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_RECOMMENDATION_QUEUE=recommendations
RABBITMQ_PREFETCH_COUNT=5
WORKER_RETRY_DELAY_SECONDS=5
WORKER_MAX_RETRIES=3
DOTNET_API_BASE_URL=http://127.0.0.1:5053
DOTNET_AI_SERVICE_TOKEN=replace-with-your-token
DOTNET_AI_SERVICE_TOKEN_HEADER=X-AI-Service-Token
DOTNET_VERIFY_TLS=true
